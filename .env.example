# =============================================
# YumyLand V1 - Environment Variables
# =============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================

# ============ DATABASE ============
# PostgreSQL connection string
# Use docker-compose.yml for local development:
#   docker compose up -d
DATABASE_URL="postgresql://yumyland:yumyland_secret@localhost:5432/yumyland?schema=public"

# ============ NEXTAUTH ============
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="gere-uma-chave-secreta-aqui-com-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ============ STRIPE (Visa / Mastercard) ============
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Get webhook secret from: https://dashboard.stripe.com/webhooks
# For local testing use Stripe CLI: stripe listen --forward-to localhost:3000/api/payments/stripe/webhook
STRIPE_WEBHOOK_SECRET="whsec_..."

# ============ PAYSUITE (M-Pesa / e-Mola) ============
# Get your credentials from: https://paysuite.co.mz
PAYSUITE_API_KEY="your-paysuite-api-key"
PAYSUITE_MERCHANT_ID="your-paysuite-merchant-id"
PAYSUITE_WEBHOOK_SECRET="your-paysuite-webhook-secret"

# ============ APP ============
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
