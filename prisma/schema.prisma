// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum Role {
  OWNER
  MASTER
  CUSTOMER
}

enum BusinessType {
  restaurant
  snackbar
  cafe
  bakery
  pizzeria
  bar
  foodtruck
}

enum Plan {
  basic
  professional
  premium
}

enum CompanyStatus {
  active
  suspended
  trial
}

enum ReservationStatus {
  pending
  confirmed
  cancelled
  completed
}

enum LoyaltyLevel {
  bronze
  silver
  gold
  diamond
}

enum SubscriptionStatus {
  active
  suspended
  cancelled
  trial
}

enum PaymentMethod {
  mpesa
  emola
  visa
  mastercard
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

enum OrderStatus {
  pending
  preparing
  ready
  delivered
  cancelled
}

// ==================== MODELS ====================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(CUSTOMER)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
  sessions Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Company {
  id        String        @id @default(cuid())
  name      String
  ownerName String
  email     String
  phone     String
  type      BusinessType
  plan      Plan          @default(basic)
  status    CompanyStatus @default(trial)
  logo      String?
  slug      String        @unique
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  users         User[]
  products      Product[]
  categories    Category[]
  reservations  Reservation[]
  customers     Customer[]
  subscriptions Subscription[]
  payments      Payment[]
  orders        Order[]

  @@map("companies")
}

model Product {
  id             String   @id @default(cuid())
  name           String
  description    String
  price          Float
  categoryId     String
  category       Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  photo          String?
  stock          Int      @default(0)
  available      Boolean  @default(true)
  isPromotion    Boolean  @default(false)
  promotionPrice Float?
  isCombo        Boolean  @default(false)
  comboItems     String[] @default([])
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orderItems OrderItem[]

  @@map("products")
}

model Category {
  id           String   @id @default(cuid())
  name         String
  description  String
  productCount Int      @default(0)
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  products Product[]

  @@map("categories")
}

model Reservation {
  id            String            @id @default(cuid())
  customerName  String
  customerPhone String
  date          String
  time          String
  guests        Int
  status        ReservationStatus @default(pending)
  notes         String?
  prepaid       Boolean           @default(false)
  amount        Float?
  companyId     String
  company       Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  payments Payment[]

  @@map("reservations")
}

model Customer {
  id            String       @id @default(cuid())
  name          String
  email         String
  phone         String
  points        Int          @default(0)
  level         LoyaltyLevel @default(bronze)
  totalSpent    Float        @default(0)
  joinDate      DateTime     @default(now())
  companyId     String
  company       Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  digitalCardId String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  orders Order[]

  @@map("customers")
}

model Subscription {
  id            String             @id @default(cuid())
  companyId     String
  company       Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyName   String
  plan          Plan
  status        SubscriptionStatus @default(trial)
  startDate     DateTime
  endDate       DateTime
  amount        Float
  paymentMethod PaymentMethod
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  payments Payment[]

  @@map("subscriptions")
}

model Payment {
  id             String        @id @default(cuid())
  amount         Float
  currency       String        @default("MZN")
  method         PaymentMethod
  status         PaymentStatus @default(pending)
  reference      String?
  transactionId  String?       @unique
  companyId      String
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  reservationId  String?
  reservation    Reservation?  @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  orderId        String?
  order          Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("payments")
}

model Order {
  id         String      @id @default(cuid())
  customerId String?
  customer   Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  companyId  String
  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  status     OrderStatus @default(pending)
  total      Float
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  items    OrderItem[]
  payments Payment[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int
  price     Float
  subtotal  Float

  @@map("order_items")
}
